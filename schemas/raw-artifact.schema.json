{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RawArtifact",
  "type": "object",
  "required": ["id", "cveId", "source", "trustClass", "title", "observedAt"],
  "properties": {
    "id": { "type": "string" },
    "cveId": { "type": "string" },
    "source": {
      "enum": ["KEV", "EPSS", "NUCLEI", "METASPLOIT", "EXPLOITDB", "POC_GITHUB", "OSV"]
    },
    "trustClass": {
      "enum": ["authoritative", "high", "medium", "low"]
    },
    "maturityTag": {
      "enum": ["README-only", "has-code", "verified", ""]
    },
    "title": { "type": "string" },
    "url": { "type": "string" }
  }
}
