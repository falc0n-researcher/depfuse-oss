/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# ── Test and profiling ────────────────────────────────────────────────────────
*.test
*.out
coverage.txt
coverage.html
*.prof
*.trace

# ── Go workspace ──────────────────────────────────────────────────────────────
go.work
go.work.sum

# ── Vendoring (optional) ──────────────────────────────────────────────────────
/vendor/

# ── IDE and editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.code-workspace
.cursor/

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Secrets and local config ──────────────────────────────────────────────────
.env
*.env.local
*.env.*.local
.envrc

# ── Local intelligence databases and clone cache (never commit) ───────────────
*.db
*.db-shm
*.db-wal
.depfuse/
depfuse-repos/

# ── Testdata — generated fixtures ────────────────────────────────────────────
# Pinned test snapshot is generated by `make testdata` — do not commit
/testdata/intel.db

# ── Demo package generated intel ─────────────────────────────────────────────
/demo_package/intel.db
/demo_package/intel.db-shm
/demo_package/intel.db-wal
/demo_package/reports/

# ── Embedded first-run snapshot IS committed (go:embed needs it at build time)
# Built by `make snapshot` — exempt from the *.db rule above
!/internal/intel/snapshot/slim.db

# ── Report and demo output ────────────────────────────────────────────────────
/reports/
/tmp/

# ── Release tooling ───────────────────────────────────────────────────────────
.goreleaser.yaml.bak

# ── Claude Code project files ─────────────────────────────────────────────────
.claude/
